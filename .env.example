# =============================================================================
# Jarvis Corunda - Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local y llena los valores reales.
# cp .env.example .env.local
# =============================================================================

# --- Base de Datos (PostgreSQL) ---
# Conexión principal usada por Prisma y la app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jarvis?schema=public"

# --- Autenticación (NextAuth v5) ---
# Secreto para firmar tokens JWT. Genera uno con: openssl rand -base64 32
AUTH_SECRET="genera-un-secreto-seguro-aqui"
# URL base de la app (necesaria para NextAuth)
NEXTAUTH_URL="http://localhost:3000"

# --- IA: Anthropic (Claude) ---
# Usado para generación de estrategias, copies, image prompts y video scripts
ANTHROPIC_API_KEY="sk-ant-tu-api-key-aqui"

# --- IA: OpenAI (DALL-E 3) ---
# Usado para generación de imágenes
OPENAI_API_KEY="sk-tu-api-key-aqui"

# --- Supabase (Storage - opcional) ---
# Para almacenamiento de archivos/imágenes generadas
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# --- n8n (Automatización - opcional) ---
# URL base de tu instancia n8n para webhooks
N8N_WEBHOOK_BASE_URL="http://localhost:5678"

# --- App ---
# URL pública de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
